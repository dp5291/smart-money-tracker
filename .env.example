# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────
# Install PostgreSQL locally, then create a database named "smartmoney"
# Command: createdb smartmoney
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smartmoney

# ── Redis (used by Celery for background tasks) ────────────────
# Install Redis: brew install redis (Mac) or sudo apt install redis (Linux)
REDIS_URL=redis://localhost:6379/0

# ── News API (free at newsapi.org — 100 requests/day free) ────
NEWSAPI_KEY=your_newsapi_key_here

# ── Reddit API (free — register at reddit.com/prefs/apps) ─────
# Create a "script" type app. Takes 2 minutes.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=SmartMoneyTracker/1.0

# ── Alpha Vantage (free — 25 calls/day at alphavantage.co) ────
# Used for VIX and DXY macro data
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── Model settings ─────────────────────────────────────────────
MODEL_DIR=./models/saved
LOOKBACK_DAYS=60
PREDICTION_THRESHOLD_BULL=0.60
PREDICTION_THRESHOLD_BEAR=0.40

# ── Tickers to track ──────────────────────────────────────────
TICKERS=AAPL,NVDA,TSLA,BTC-USD,MSFT,AMZN

# ── Security ──────────────────────────────────────────────────
# Generate keys: python api/security.py
API_KEYS=generate_with_python_api_security_py
WEBHOOK_SECRET=generate_with_python_api_security_py

# Set to true only during local development (removes auth)
DEV_MODE=true

# Your frontend URL (localhost for dev, your domain for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Set to true in production to hide /docs endpoint
HIDE_DOCS=false
